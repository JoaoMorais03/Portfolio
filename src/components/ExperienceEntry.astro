---
interface Props {
  role: string;
  company: string;
  location: string;
  startDate: string;
  endDate?: string;
  bullets: string[];
  technologies: string[];
}

const { role, company, location, startDate, endDate, bullets, technologies } = Astro.props;
const period = endDate ? `${startDate} — ${endDate}` : `${startDate} — Present`;
const isCurrent = !endDate;
---

<div class="group relative pl-6 border-l border-accent/20 hover:border-accent/40 transition-colors duration-200">
  <!-- Timeline dot -->
  <div class:list={[
    'absolute -left-[5px] top-1.5 w-[9px] h-[9px] rounded-full border-2 border-bg',
    isCurrent ? 'bg-accent' : 'bg-border-hover'
  ]} />

  <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-0.5 mb-2">
    <div>
      <h3 class="font-semibold tracking-tight">{role}</h3>
      <p class="text-text-muted text-sm">
        {company}<span class="text-text-muted/50"> · {location}</span>
      </p>
    </div>
    <span class="text-xs font-mono text-text-muted/70 shrink-0 tabular-nums">{period}</span>
  </div>

  <ul class="space-y-1.5 mb-3 mt-3">
    {bullets.map((bullet) => (
      <li class="text-sm text-text-muted leading-relaxed pl-4 relative before:content-[''] before:absolute before:left-0 before:top-[10px] before:w-1 before:h-1 before:rounded-full before:bg-border-hover">
        {bullet}
      </li>
    ))}
  </ul>

  <div class="flex flex-wrap gap-1.5">
    {technologies.map((tech) => (
      <span class="px-2 py-0.5 text-[11px] font-mono text-text-muted/80 bg-bg-elevated border border-border rounded-md">
        {tech}
      </span>
    ))}
  </div>
</div>
